# PostgreSQL
CANDLE_DB_URL=postgresql+asyncpg://candle:candle@localhost:5432/candle
CANDLE_DB_URL_TEST=postgresql+asyncpg://candle:candle@localhost:5432/candle_test

# Exchanges (all optional for public OHLCV data)
BINANCE_API_KEY=
BINANCE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # market alerts (traders)
TELEGRAM_ADMIN_CHAT_ID=  # operator alerts: job failures, heartbeats (can equal TELEGRAM_CHAT_ID in dev)

# Scheduler
FETCH_INTERVAL_MINUTES=60
SCREEN_INTERVAL_MINUTES=60
DEFAULT_TIMEFRAME=4h
ALERT_DEDUP_HOURS=4

# API
API_KEY=

# App
ENV=development
